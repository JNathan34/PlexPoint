# Plex integration (used by `npm run generate:plex-preview`, `npm run dev:server`,
# and Cloudflare Pages Functions runtime variables)
#
# Example:
# PLEX_URL=http://192.168.1.10:32400
# PLEX_TOKEN=xxxxxxxxxxxxxxxxxxxx
#
# Optional: if you have multiple libraries, set the section id explicitly.
# You can find ids by running the app and visiting: GET /api/plex/sections
# You can inspect movie collections at: GET /api/plex/collections
PLEX_URL=
PLEX_TOKEN=
PLEX_MOVIE_SECTION_ID=
PLEX_TV_SECTION_ID=

# Pick the movie collection shown in the website.
# Set either the exact title or the collection id. If both are set, the id wins.
PLEX_COLLECTION_ID=
PLEX_COLLECTION_TITLE=

# If you deploy on Cloudflare Pages, the Plex URL must be reachable from Cloudflare.
# For a home Plex server, that usually means exposing it safely with Cloudflare Tunnel.
